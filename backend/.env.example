SPRING_PROFILES_ACTIVE=dev
DATABASE_URL=jdbc:postgresql://localhost:5432/nexusmind
DATABASE_USER=nexusmind
DATABASE_PASSWORD=nexusmind

AI_PROVIDER=openai_compatible
# OpenAI: https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
# Gemini (Google AI Studio, API compatível com OpenAI): https://generativelanguage.googleapis.com/v1beta/openai
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
# Ex. Gemini: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=90
# Tentativas à API (503 Gemini = sobrecarga; o backend usa espera entre tentativas)
AI_MAX_RETRIES=5

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_RATE_LIMIT_PER_MINUTE=30
