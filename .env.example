# Raiz — referência; copie valores para backend/.env e frontend/.env.local

# Backend (Railway / local)
SPRING_PROFILES_ACTIVE=dev
DATABASE_URL=jdbc:postgresql://localhost:5432/nexusmind
DATABASE_USER=nexusmind
DATABASE_PASSWORD=nexusmind

# IA — OpenAI-compatible (OpenRouter, Groq, etc.)
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=google/gemma-2-9b-it:free
AI_TIMEOUT_SECONDS=90
AI_MAX_RETRIES=2

# CORS (origens do frontend)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limit (requisições por minuto por IP)
APP_RATE_LIMIT_PER_MINUTE=30

# Frontend (Vercel / local)
NEXT_PUBLIC_API_URL=http://localhost:8080
